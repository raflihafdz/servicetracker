// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Vehicle {
  id          String      @id @default(uuid())
  name        String      // e.g. "FOAM TENDER 1 (SCANIA)"
  type        String      // "TRUCK", "AMBULANCE", "RIV"
  plateNumber String?     // Plate number or other identifiers
  checklists  Checklist[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Checklist {
  id                 String           @id @default(uuid())
  vehicleId          String
  vehicle            Vehicle          @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  date               DateTime
  status             String           // "LULUS", "DITAHAN", "TIDAK_LULUS"
  notes              String?          // General notes (e.g. "Turret control macet")
  
  // Inspectors (Pemeriksa) - Array of { name: string, signature: string }
  inspectors         Json             
  
  // Approval (Persetujuan Kepala Unit)
  approved           Boolean          @default(false)
  approvedBy         String           @default("HERRY PANGESTUADI")
  approvedNip        String           @default("198805262010121004")
  approvedTitle      String           @default("Kepala Unit PKP-PK") // or "Koordinator Unit PKP-PK"
  approvedAt         DateTime?
  approvalSignature  String?          // base64 signature image
  
  items              ChecklistItem[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

model ChecklistItem {
  id          String    @id @default(uuid())
  checklistId String
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  name        String    // e.g. "Bahan Bakar"
  category    String    // "UMUM" or "PERLENGKAPAN"
  method      String    // "TAMPILAN" or "FUNGSI"
  result      String    // "BAGUS", "KURANG", "RUSAK"
  notes       String?   // "keterangan"
}
